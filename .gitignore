# Wordpress - ignore core, configuration, examples, uploads and logs.
# https://github.com/github/gitignore/blob/main/WordPress.gitignore

# Environment files (contains sensitive credentials)
.env

# Composer dependencies
/vendor/

# Core
#
# Note: if you want to stage/commit WP core files
# you can delete this whole section/until Configuration.
/wp-admin/
/wp-content/index.php
/wp-content/languages
/wp-content/plugins/index.php
/wp-content/themes/index.php
/wp-includes/
/index.php
/license.txt
/readme.html
/wp-*.php
/xmlrpc.php

# Configuration
wp-config.php

# Example themes (WordPress bundled)
/wp-content/themes/twenty*/

# Example plugin
/wp-content/plugins/hello.php

# Third-party plugins (install via WordPress admin or composer)
/wp-content/plugins/advanced-custom-fields/
/wp-content/plugins/advanced-custom-fields-pro/
/wp-content/plugins/akismet/

# Uploads
/wp-content/uploads/

# Log files
*.log

# htaccess
/.htaccess

# macOS
.DS_Store

# All plugins - uncomment to ignore ALL plugins
#/wp-content/plugins/*
#!/wp-content/plugins/.gitkeep

# All themes - uncomment to ignore ALL themes except custom
#/wp-content/themes/*
#!/wp-content/themes/.gitkeep
#!/wp-content/themes/hookedonaneedle/